# ============================================================
# 견적서 관리 시스템 환경변수
# 이 파일을 .env.local로 복사 후 실제 값으로 채워주세요
# ============================================================

# Notion API 설정
# https://www.notion.so/my-integrations 에서 발급
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 데이터베이스 ID
# 견적서 데이터베이스 URL에서 추출: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 견적 항목 데이터베이스 ID
NOTION_ITEMS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
